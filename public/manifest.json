{
  "name": "琉璃小工具",
  "version": "1.4.4",
  "description": "超级无敌方便工具",
  "manifest_version": 3,
  "minimum_chrome_version": "107",
  "browser_specific_settings": {
    "gecko": {
      "id": "{891e0a50-2117-4413-b37d-5b77fbc281fd}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://apex.prosperousuniverse.com/"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://apex.prosperousuniverse.com/*"
      ],
      "js": [
        "refined-prun-prepare.js",
        "refined-prun-startup.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "*.js",
        "*.css",
        "*.svg",
        "*.json",
        "*.woff2",
        "*.ttf"
      ],
      "matches": [
        "https://apex.prosperousuniverse.com/*"
      ]
    }
  ]
}
